# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Go API
GO_API_URL=http://localhost:8081
GO_API_INTERNAL_URL=http://127.0.0.1:8081
BACKEND_ADDR=:8081
BACKEND_DATA_DIR=.backend-data
APP_ORIGIN=http://localhost:3000
# Optional: comma-separated list of additional CORS origins.
# Example: ALLOWED_ORIGINS=https://example.com,https://www.example.com
ALLOWED_ORIGINS=

# Postgres. Required for admin auth, optional for the content layer (which
# still falls back to local file storage if unset). Bring up the included
# docker-compose with `docker compose up -d`.
DATABASE_URL=postgres://hello:hello@127.0.0.1:5432/hello_gutsyang?sslmode=disable

# Session cookie hardening. Values: auto (default; uses https://APP_ORIGIN to
# decide), on (force Secure), off (force non-Secure for plain-http dev).
COOKIE_SECURE=auto

# Admin bootstrap account
# Recommended: leave ADMIN_BOOTSTRAP_PASSWORD blank in production and provide
# ADMIN_BOOTSTRAP_PASSWORD_HASH (a bcrypt hash) instead.
# Generate with:
#   cd backend && go run ./cmd/api hash 'your-strong-password'
# (or any bcrypt tool that emits a $2a$/$2b$/$2y$ string).
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_PASSWORD_HASH=
ADMIN_SESSION_COOKIE=hello_gutsyang_admin_session

# Media upload limits (10 MiB default).
MEDIA_MAX_UPLOAD_BYTES=10485760

# Rate limits: <BURST> requests every <WINDOW> per IP.
# Window accepts Go duration syntax (e.g. 30s, 5m, 1h).
RATE_LIMIT_LOGIN_BURST=10
RATE_LIMIT_LOGIN_WINDOW=5m
RATE_LIMIT_CHAT_BURST=5
RATE_LIMIT_CHAT_WINDOW=30s

# Slow-path login lockout. After THRESHOLD failures (per email OR per IP)
# within WINDOW, further attempts get 429 + Retry-After=BLOCK_FOR seconds.
# This is an upper layer on top of the token-bucket limiter above.
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_WINDOW=15m
LOGIN_LOCKOUT_BLOCK_FOR=15m

# DeepSeek
# Available models: deepseek-v4-flash (fast & cheap, default), deepseek-v4-pro (higher quality)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
